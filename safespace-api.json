{
  "openapi": "3.0.0",
  "info": {
    "title": "SafeSpace API",
    "version": "1.4.0",
    "description": "Dokumentasi API untuk SafeSpace Backend. Menyediakan layanan pelaporan insiden secara aman beserta sistem autentikasi dan manajemen pengguna/admin."
  },
  "servers": [
    {
      "url": "https://safespacebackend.vercel.app/api",
      "description": "Production Server"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "Endpoint terkait autentikasi pengguna dan sesi."
    },
    {
      "name": "Report",
      "description": "Endpoint terkait pembuatan dan pengelolaan laporan oleh pengguna."
    },
    {
      "name": "Admin",
      "description": "Endpoint khusus admin untuk mengelola status laporan dan profil admin."
    },
    {
      "name": "User",
      "description": "Endpoint untuk melihat dan memperbarui profil pengguna."
    },
    {
      "name": "Notification",
      "description": "Endpoint untuk melihat dan mengelola notifikasi pengguna dan admin."
    }
  ],
  "paths": {
    "/auth/sign-up": {
      "post": {
        "tags": ["Auth"],
        "summary": "Registrasi pengguna baru",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SignUpRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Berhasil mendaftar" }
        }
      }
    },
    "/auth/admin/sign-up": {
      "post": {
        "tags": ["Auth"],
        "summary": "Registrasi admin baru",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SignUpRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Berhasil mendaftar sebagai admin" }
        }
      }
    },
    "/auth/sign-in": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login pengguna",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SignInRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Berhasil login" }
        }
      }
    },
    "/auth/sign-out": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout pengguna",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Berhasil logout" }
        }
      }
    },
    "/auth/get-session": {
      "get": {
        "tags": ["Auth"],
        "summary": "Mendapatkan informasi sesi saat ini",
        "responses": {
          "200": { "description": "Informasi sesi berhasil diambil" }
        }
      }
    },
    "/auth/update-password": {
      "post": {
        "tags": ["Auth"],
        "summary": "Memperbarui password pengguna",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdatePasswordRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Password berhasil diperbarui" }
        }
      }
    },
    "/auth/resend-verification-email": {
      "post": {
        "tags": ["Auth"],
        "summary": "Mengirim ulang email verifikasi",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EmailRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Email verifikasi berhasil dikirim" }
        }
      }
    },
    "/auth/request-password-reset": {
      "post": {
        "tags": ["Auth"],
        "summary": "Meminta reset password",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EmailRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Instruksi reset password telah dikirim" }
        }
      }
    },
    "/report/create": {
      "post": {
        "tags": ["Report"],
        "summary": "Membuat laporan baru",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateReportRequest" }
            }
          }
        },
        "responses": {
          "201": { "description": "Laporan berhasil dibuat" }
        }
      }
    },
    "/report/evidence/upload-url": {
      "post": {
        "tags": ["Report"],
        "summary": "Mendapatkan signed URL untuk upload bukti",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EvidenceUploadRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Signed URL berhasil di-generate" }
        }
      }
    },
    "/report/{id}": {
      "get": {
        "tags": ["Report"],
        "summary": "Mendapatkan detail laporan berdasarkan ID",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "UUID laporan"
          }
        ],
        "responses": {
          "200": { "description": "Detail laporan" }
        }
      },
      "post": {
        "tags": ["Report"],
        "summary": "Membatalkan laporan",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "UUID laporan yang akan dibatalkan"
          }
        ],
        "responses": {
          "200": { "description": "Laporan berhasil dibatalkan" }
        }
      }
    },
    "/report": {
      "get": {
        "tags": ["Report"],
        "summary": "Mendapatkan semua laporan yang dibuat pengguna saat ini",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10, "maximum": 100 }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Cari berdasarkan jenis insiden atau deskripsi insiden"
          }
        ],
        "responses": {
          "200": { "description": "Daftar laporan" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/report/{id}/evidence": {
      "post": {
        "tags": ["Report"],
        "summary": "Tambah bukti ke laporan yang sudah ada",
        "description": "Memindahkan file dari `temp/` ke `permanent/<reportId>/` dan menyimpan path baru ke tabel `evidence_asset`. Bukti lama tidak dihapus. Hanya pemilik laporan yang dapat mengakses endpoint ini.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "UUID laporan"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AddEvidenceRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bukti berhasil ditambahkan. Mengembalikan laporan beserta seluruh evidence terbaru.",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Bukti berhasil ditambahkan",
                  "data": { "id": "uuid", "reportCode": "RPT-xxxx", "evidenceAssets": [] }
                }
              }
            }
          },
          "400": { "description": "Validasi gagal — evidencePaths kosong atau lebih dari 5 item" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden — bukan pemilik laporan" },
          "404": { "description": "Laporan tidak ditemukan" }
        }
      }
    },
    "/report/{id}/download": {
      "get": {
        "tags": ["Report"],
        "summary": "Download laporan dalam format PDF",
        "description": "Menghasilkan PDF yang berisi semua detail laporan dan daftar nama file bukti. Pemilik laporan atau admin dapat mengakses endpoint ini.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "UUID laporan"
          }
        ],
        "responses": {
          "200": {
            "description": "File PDF laporan",
            "headers": {
              "Content-Disposition": {
                "schema": { "type": "string" },
                "example": "attachment; filename=\"laporan-RPT-xxxx.pdf\""
              }
            },
            "content": {
              "application/pdf": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": { "description": "ID bukan UUID valid" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden — bukan pemilik laporan dan bukan admin" },
          "404": { "description": "Laporan tidak ditemukan" }
        }
      }
    },
    "/report/{id}/history": {
      "get": {
        "tags": ["Report"],
        "summary": "Lihat riwayat perubahan status laporan",
        "description": "Mengembalikan timeline perubahan status laporan urut dari terbaru. Setiap entri menyertakan `changedByName` yang di-resolve dari tabel `user` atau `admin`. Hanya pemilik laporan atau admin yang dapat mengakses.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "UUID laporan"
          }
        ],
        "responses": {
          "200": {
            "description": "Riwayat status laporan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "message": { "type": "string" },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/ReportStatusHistory" }
                    }
                  }
                }
              }
            }
          },
          "400": { "description": "ID bukan UUID valid" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden — bukan pemilik laporan dan bukan admin" },
          "404": { "description": "Laporan tidak ditemukan" }
        }
      }
    },
    "/admin/report": {
      "get": {
        "tags": ["Admin"],
        "summary": "Mendapatkan seluruh laporan yang masuk (Role Admin)",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10, "maximum": 100 }
          }
        ],
        "responses": {
          "200": { "description": "Daftar laporan untuk admin" }
        }
      }
    },
    "/admin/report/{id}": {
      "get": {
        "tags": ["Admin"],
        "summary": "Mendapatkan detail laporan",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": { "description": "Detail laporan spesifik" }
        }
      }
    },
    "/admin/report/{id}/status": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Memperbarui status laporan",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateStatusReportRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Status laporan berhasil diperbarui" }
        }
      }
    },
    "/admin/profile": {
      "get": {
        "tags": ["Admin"],
        "summary": "Mendapatkan profil admin",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Data profil admin" }
        }
      },
      "patch": {
        "tags": ["Admin"],
        "summary": "Memperbarui profil admin",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateAdminProfileRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Profil admin berhasil diperbarui" }
        }
      }
    },
    "/admin/profile-picture/upload-url": {
      "post": {
        "tags": ["Admin"],
        "summary": "Mendapatkan signed URL untuk upload foto profil admin",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProfilePictureUploadRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Signed URL untuk foto profil admin" }
        }
      }
    },
    "/admin/profile-picture": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Mengubah path foto profil admin",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateProfilePictureRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Foto profil admin berhasil diubah" }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "Menghapus foto profil admin",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Foto profil admin berhasil dihapus" }
        }
      }
    },
    "/user/profile": {
      "get": {
        "tags": ["User"],
        "summary": "Mendapatkan profil pengguna",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Data profil pengguna" }
        }
      },
      "patch": {
        "tags": ["User"],
        "summary": "Memperbarui profil pengguna",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateUserProfileRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Profil pengguna berhasil diperbarui" }
        }
      }
    },
    "/user/profile-picture/upload-url": {
      "post": {
        "tags": ["User"],
        "summary": "Mendapatkan signed URL untuk upload foto profil pengguna",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ProfilePictureUploadRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Signed URL untuk foto profil pengguna" }
        }
      }
    },
    "/user/profile-picture": {
      "patch": {
        "tags": ["User"],
        "summary": "Mengubah path foto profil pengguna",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateProfilePictureRequest" }
            }
          }
        },
        "responses": {
          "200": { "description": "Foto profil pengguna berhasil diubah" }
        }
      },
      "delete": {
        "tags": ["User"],
        "summary": "Menghapus foto profil pengguna",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": { "description": "Foto profil pengguna berhasil dihapus" }
        }
      }
    },
    "/notifications": {
      "get": {
        "tags": ["Notification"],
        "summary": "Ambil daftar notifikasi",
        "description": "Mengembalikan notifikasi milik user atau admin yang sedang login, urut dari terbaru. Role ditentukan otomatis dari JWT. Filter `unread=true` untuk notifikasi yang belum dibaca saja.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10, "maximum": 100 }
          },
          {
            "name": "unread",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "enum": ["true"] },
            "description": "Jika diisi `true`, hanya kembalikan notifikasi yang belum dibaca"
          }
        ],
        "responses": {
          "200": {
            "description": "Daftar notifikasi beserta info pagination",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PaginatedNotificationsResponse" }
              }
            }
          },
          "400": { "description": "Validasi query parameter gagal" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/notifications/unread-count": {
      "get": {
        "tags": ["Notification"],
        "summary": "Ambil jumlah notifikasi yang belum dibaca",
        "description": "Mengembalikan total notifikasi yang belum dibaca milik user atau admin yang sedang login. Digunakan untuk menampilkan badge.",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Jumlah notifikasi belum dibaca",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UnreadCountResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/notifications/read-all": {
      "patch": {
        "tags": ["Notification"],
        "summary": "Tandai semua notifikasi sebagai dibaca",
        "description": "Mengubah `isRead` menjadi `true` untuk semua notifikasi milik user atau admin yang sedang login. Mengembalikan jumlah baris yang diperbarui.",
        "security": [{ "BearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Semua notifikasi berhasil ditandai sebagai dibaca",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MarkAllReadResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/notifications/{id}/read": {
      "patch": {
        "tags": ["Notification"],
        "summary": "Tandai satu notifikasi sebagai dibaca",
        "description": "Mengubah `isRead` menjadi `true` untuk notifikasi dengan ID yang diberikan. Hanya pemilik notifikasi yang dapat mengaksesnya.",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "UUID notifikasi"
          }
        ],
        "responses": {
          "200": {
            "description": "Notifikasi berhasil ditandai sebagai dibaca",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "message": { "type": "string" },
                    "data": { "$ref": "#/components/schemas/Notification" }
                  }
                }
              }
            }
          },
          "400": { "description": "ID bukan UUID valid" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden — bukan pemilik notifikasi" },
          "404": { "description": "Notifikasi tidak ditemukan" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "SignUpRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8, "maxLength": 50 },
          "confirmPassword": { "type": "string", "minLength": 8, "maxLength": 50 }
        },
        "required": ["email", "password", "confirmPassword"]
      },
      "SignInRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        },
        "required": ["email", "password"]
      },
      "UpdatePasswordRequest": {
        "type": "object",
        "properties": {
          "currentPassword": { "type": "string" },
          "newPassword": { "type": "string", "minLength": 8, "maxLength": 50 },
          "confirmPassword": { "type": "string", "minLength": 8, "maxLength": 50 }
        },
        "required": ["currentPassword", "newPassword", "confirmPassword"]
      },
      "EmailRequest": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" }
        },
        "required": ["email"]
      },
      "CreateReportRequest": {
        "type": "object",
        "properties": {
          "incident": { "type": "string" },
          "date": { "type": "string", "format": "date-time" },
          "location": { "type": "string" },
          "incidentDesc": { "type": "string" },
          "perpetratorDesc": { "type": "string" },
          "evidencePaths": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["incident", "date", "location", "incidentDesc", "perpetratorDesc"]
      },
      "EvidenceUploadRequest": {
        "type": "object",
        "properties": {
          "fileName": { "type": "string" },
          "fileType": {
            "type": "string",
            "enum": ["image/jpeg", "image/png", "image/jpg", "application/pdf", "video/mp4", "video/mkv"]
          },
          "fileSize": { "type": "number", "maximum": 52428800 }
        },
        "required": ["fileName", "fileType", "fileSize"]
      },
      "UpdateStatusReportRequest": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["RECEIVED", "PROCESS", "REVIEW", "ASSISTANCE", "REJECTED", "DONE", "CANCELLED"]
          }
        },
        "required": ["status"]
      },
      "UpdateAdminProfileRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 2, "maxLength": 50 },
          "unit": { "type": "string", "minLength": 2, "maxLength": 100 }
        },
        "required": ["name", "unit"]
      },
      "UpdateUserProfileRequest": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 2, "maxLength": 50 },
          "phoneNumber": { "type": "string", "minLength": 1, "maxLength": 25 },
          "nim": { "type": "string", "minLength": 10, "maxLength": 15 },
          "department": { "type": "string", "minLength": 2, "maxLength": 100 },
          "faculty": { "type": "string", "minLength": 2, "maxLength": 100 },
          "enrollmentYear": { "type": "integer", "minimum": 2000 }
        },
        "required": ["name", "phoneNumber", "nim", "department", "faculty", "enrollmentYear"]
      },
      "ProfilePictureUploadRequest": {
        "type": "object",
        "properties": {
          "fileName": { "type": "string", "minLength": 1, "maxLength": 100 },
          "fileType": {
            "type": "string",
            "enum": ["image/jpeg", "image/png", "image/jpg"]
          },
          "fileSize": { "type": "number", "maximum": 10485760 }
        },
        "required": ["fileName", "fileType", "fileSize"]
      },
      "UpdateProfilePictureRequest": {
        "type": "object",
        "properties": {
          "profilePicturePath": { "type": "string" }
        },
        "required": ["profilePicturePath"]
      },
      "AddEvidenceRequest": {
        "type": "object",
        "properties": {
          "evidencePaths": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "maxItems": 5,
            "description": "Array path file bukti dari Supabase Storage (hasil upload ke temp/). Minimal 1, maksimal 5 per request."
          }
        },
        "required": ["evidencePaths"]
      },
      "ReportStatusHistory": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "reportId": { "type": "string", "format": "uuid" },
          "oldStatus": {
            "type": "string",
            "enum": ["RECEIVED", "PROCESS", "REVIEW", "ASSISTANCE", "REJECTED", "DONE", "CANCELLED"],
            "nullable": true,
            "description": "Status sebelum perubahan. Null untuk entri pertama saat laporan dibuat."
          },
          "newStatus": {
            "type": "string",
            "enum": ["RECEIVED", "PROCESS", "REVIEW", "ASSISTANCE", "REJECTED", "DONE", "CANCELLED"]
          },
          "changedBy": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "description": "UUID user atau admin yang melakukan perubahan."
          },
          "changedByRole": {
            "type": "string",
            "enum": ["USER", "ADMIN", "SYSTEM"]
          },
          "changedByName": {
            "type": "string",
            "nullable": true,
            "description": "Nama changedBy yang di-resolve dari tabel user atau admin. Null jika belum mengisi profil."
          },
          "notes": { "type": "string", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "recipientId": { "type": "string", "format": "uuid" },
          "recipientRole": { "type": "string", "enum": ["USER", "ADMIN"] },
          "type": {
            "type": "string",
            "enum": ["NEW_REPORT_SUBMITTED", "REPORT_STATUS_CHANGED", "REPORT_CANCELLED"],
            "description": "Jenis event yang memicu notifikasi."
          },
          "title": { "type": "string" },
          "message": { "type": "string" },
          "relatedId": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "description": "ID laporan yang terkait dengan notifikasi ini."
          },
          "isRead": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "PaginatedNotificationsResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Notification" }
          },
          "pagination": {
            "type": "object",
            "properties": {
              "size": { "type": "integer" },
              "page": { "type": "integer" },
              "total": { "type": "integer" },
              "totalPages": { "type": "integer" }
            }
          }
        }
      },
      "UnreadCountResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "count": { "type": "integer", "description": "Jumlah notifikasi yang belum dibaca" }
            }
          }
        }
      },
      "MarkAllReadResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "count": { "type": "integer", "description": "Jumlah notifikasi yang berhasil ditandai sebagai dibaca" }
            }
          }
        }
      }
    }
  }
}